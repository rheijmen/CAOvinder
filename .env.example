MISTRAL_API_KEY=your-mistral-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

CAO_ENGINE_DATA_DIR=./data
CAO_ENGINE_LOG_LEVEL=INFO
CAO_ENGINE_LOG_FORMAT=console
CAO_ENGINE_OCR_MODEL=mistral-ocr-latest
CAO_ENGINE_TABLE_FORMAT=html
CAO_ENGINE_EXTRACT_HEADERS=true
CAO_ENGINE_EXTRACT_FOOTERS=true

# Multi-LLM Extraction
CAO_ENGINE_GEMINI_MODEL=gemini-2.5-flash-latest
